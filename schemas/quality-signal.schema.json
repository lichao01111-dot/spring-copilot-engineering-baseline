{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "隐私安全质量信号",
  "type": "object",
  "additionalProperties": false,
  "required": ["skill", "outcome", "reason_code"],
  "properties": {
    "skill": {"type": "string", "minLength": 1}, "version": {"type": "string"},
    "outcome": {"type": "string", "enum": ["passed", "failed", "blocked", "overridden"]},
    "reason_code": {"type": "string", "pattern": "^[A-Z0-9_]+$"},
    "check_results": {"type": "object", "additionalProperties": {"type": "string"}},
    "human_override": {"type": "boolean"}, "task_kind": {"type": "string"}
  }
}
